# ============================================================
# Azul Horizonte Boutique Hotel — Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# El archivo .env NUNCA se sube a git.
# ============================================================

# --- Claude AI ---
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Zapier ---
# URL del Catch Hook. La verificación de disponibilidad ocurre en el backend;
# Zapier solo crea el evento + envía correo + registra en Sheets.
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXXXX/YYYYYYY/

# --- Google Calendar (verificación de disponibilidad) ---
# Service Account JSON completo en UNA SOLA LÍNEA (sin saltos de línea reales)
# Crear en: console.cloud.google.com → IAM → Cuentas de servicio → Claves → JSON
# Compartir el calendario con el email del service account (permiso: "Ver todos los detalles")
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# ID del calendario del hotel
# Obtener en Google Calendar → Configuración del calendario → "Dirección del calendario"
GOOGLE_CALENDAR_HOTEL=xxxx@group.calendar.google.com

# --- n8n (solo para docker-compose local) ---
# Credenciales de acceso al panel de n8n en http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambia_esta_contraseña
