    {
      "parameters": {
        "jsCode": "// 'mañana' en hora Guatemala (UTC-6)\nconst nowGT = new Date(Date.now() - 6 * 60 * 60 * 1000);\nconst tomorrowGT = new Date(nowGT);\ntomorrowGT.setUTCDate(tomorrowGT.getUTCDate() + 1);\nconst tStr = tomorrowGT.toISOString().split('T')[0];\n\nreturn $input.all().filter(item => {\n  const r = item.json;\n  // Google Sheets devuelve 'YYYY-MM-DD HH:MM:SS' (espacio) o 'YYYY-MM-DD'\n  // Tomamos solo la parte de fecha para comparar\n  const ci = String(r.check_in || '').trim().split(/[ T]/)[0];\n  return ci === tStr\n    && r.status === 'confirmed'\n    && r.reminder_24h !== 'TRUE'\n    && r.reminder_24h !== true;\n});"
      },
      "id": "aa010001-0003-0003-0003-000000000003",
      "name": "Filtrar check-ins de mañana",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
